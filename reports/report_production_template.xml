<odoo>

<template id="report_production_template">

<t t-call="web.external_layout">

<div class="page">

<h2>Relatório de Produção do Cilindro</h2>

<p>
<strong>Ordem:</strong>
<span t-esc="doc.name"/>
</p>

<p>
<strong>Serial:</strong>
<span t-esc="doc.lot_producing_id.name"/>
</p>

<table class="table table-sm table-bordered">

<thead>

<tr>
<th>Máquina</th>
<th>Peça</th>
<th>Processo</th>
<th>Status</th>
</tr>

</thead>

<tbody>

<t t-foreach="doc.workorder_ids" t-as="wo">

<tr>

<td>
<span t-esc="wo.workcenter_id.name"/>
</td>

<td>
<span t-esc="wo.piece_name"/>
</td>

<td>
<span t-esc="wo.process_name"/>
</td>

<td>
<span t-esc="wo.state"/>
</td>

</tr>

</t>

</tbody>

</table>

</div>

</t>

</template>

</odoo>

<odoo>
    <template id="report_production_template">
        <t t-call="web.external_layout">
            <div class="page">
                <h2 class="mt-4">Relatório de Produção do Cilindro</h2>
                
                <div class="row mb-4">
                    <div class="col-6">
                        <strong>Ordem:</strong> <span t-field="doc.name"/>
                    </div>
                    <div class="col-6">
                        <strong>Serial:</strong> <span t-field="doc.lot_id.name"/>
                    </div>
                </div>

                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Máquina</th>
                            <th>Peça</th>
                            <th>Processo</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="doc.workorder_ids">
                            <t t-foreach="doc.workorder_ids" t-as="wo">
                                <tr>
                                    <td><span t-field="wo.workcenter_id.name"/></td>
                                    <td><span t-field="wo.piece_name"/></td>
                                    <td><span t-field="wo.process_name"/></td>
                                    <td><span t-field="wo.state"/></td>
                                </tr>
                            </t>
                        </t>
                        <t t-else="">
                            <tr>
                                <td colspan="4" class="text-center">Nenhuma ordem de trabalho encontrada</td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- =========================================================== -->
    <!-- TREE VIEW: Lista de Ordens de Trabalho -->
    <!-- =========================================================== -->
    <record id="view_cylinder_tracking_tree" model="ir.ui.view">
        <field name="name">mrp.workorder.cylinder.tree</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="serial_number" string="Serial" optional="show"/>
                <field name="piece_name" string="Peça" optional="show"/>
                <field name="process_name" string="Processo" optional="show"/>
            </xpath>
            <!-- Decorações visuais opcionais -->
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-info">state == 'pending'</attribute>
                <attribute name="decoration-success">state == 'done'</attribute>
                <attribute name="decoration-danger">state == 'cancel'</attribute>
            </xpath>
        </field>
    </record>

    <!-- =========================================================== -->
    <!-- FORM VIEW: Formulário de Ordem de Trabalho -->
    <!-- =========================================================== -->
    <record id="view_cylinder_tracking_form" model="ir.ui.view">
        <field name="name">mrp.workorder.cylinder.form</field>
        <field name="model">mrp.workorder</field>
        <!-- ✅ ID descoberto no seu sistema -->
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='production_id']" position="after">
                <field name="serial_number" readonly="1"/>
                <field name="piece_name" readonly="1"/>
                <field name="process_name" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!-- =========================================================== -->
    <!-- SEARCH VIEW: Filtros de Busca -->
    <!-- =========================================================== -->
    <record id="view_cylinder_tracking_search" model="ir.ui.view">
        <field name="name">mrp.workorder.cylinder.search</field>
        <field name="model">mrp.workorder</field>
        <!-- ✅ ID descoberto no seu sistema -->
        <field name="inherit_id" ref="mrp.view_mrp_production_work_order_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="serial_number"/>
                <field name="piece_name"/>
                <field name="process_name"/>
            </xpath>
        </field>
    </record>
</odoo>

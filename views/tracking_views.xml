<odoo>

<record id="view_cylinder_tracking_tree" model="ir.ui.view">
    <field name="name">cylinder.tracking.tree</field>
    <field name="model">mrp.workorder</field>
    <field name="arch" type="xml">

        <tree string="Rastreamento da Produção">

            <field name="workcenter_id" string="Máquina"/>
            <field name="production_id" string="Ordem"/>
            <field name="serial_number" string="Serial"/>
            <field name="piece_name" string="Peça"/>
            <field name="process_name" string="Processo"/>
            <field name="state" string="Status"/>

        </tree>

    </field>
</record>

</odoo>
